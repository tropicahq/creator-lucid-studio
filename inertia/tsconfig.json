{
	"extends": "@adonisjs/tsconfig/tsconfig.client.json",
	"compilerOptions": {
		"baseUrl": ".",
		"module": "ESNext",
		"jsx": "react-jsx",
		"paths": {
			"~/*": ["./*"],
			"~generated/*": ["../.adonisjs/client/*"],
			"~registry": ["../.adonisjs/client/registry.ts"]
		},
		"types": ["./types.d.ts"]
	},
	"include": ["./**/*.ts", "./**/*.tsx"]
}
