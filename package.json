	"license": "UNLICENSED",
	"scripts": {
		"start": "node bin/server.js",
		"build": "node ace build",
		"dev": "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"node ace jobs:listen --queue=default,emails,analysis,media-pipeline\" \"node ace serve --hmr\" --names=queue,server --kill-others",
		"test": "node ace test",
		"lint": "biome check",
		"format": "biome format --write ",
		"typecheck": "tsc --noEmit"
	},
	"imports": {
		"#controllers/*": "./app/controllers/*.js",
		"#exceptions/*": "./app/exceptions/*.js",
		"#models/*": "./app/models/*.js",
		"#mails/*": "./app/mails/*.js",
